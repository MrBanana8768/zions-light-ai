# =============================================================================
# Zion's Light AI - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust settings as needed:
#   cp .env.example .env
#
# Stack: vLLM (inference) -> context-compactor (auto-summarization proxy) -> OpenWebUI
# =============================================================================

# =============================================================================
# MODEL — any HuggingFace causal-LM repo that vLLM supports
# =============================================================================
# Default: Magnum v4 22B — creative writing fine-tune of Mistral-Small-Instruct,
# lightly aligned, mimics Claude's prose style. On A40 (48GB), FP16 is a tight
# fit so we default to FP8 weight quantization for 32K context headroom.
MODEL_REPO=anthracite-org/magnum-v4-22b
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.90
# Runtime FP8 weight quantization — halves VRAM usage, ~99% quality retention.
# Remove if your GPU has ample VRAM and you want pure FP16 quality.
VLLM_EXTRA_ARGS=--quantization fp8

# =============================================================================
# CONTEXT COMPACTOR — Claude-style auto-summarization
# =============================================================================
# When total tokens in a request exceed COMPACTOR_TARGET_TOKENS, the older
# turns get summarized into a single system message and replaced.
# Leave COMPACTOR_TARGET_TOKENS empty to auto-default to 75% of MAX_MODEL_LEN.
COMPACTOR_TARGET_TOKENS=
COMPACTOR_KEEP_RECENT_TURNS=4
COMPACTOR_SUMMARY_MAX_TOKENS=1024

# =============================================================================
# OpenWebUI
# =============================================================================
WEBUI_AUTH=false
WEBUI_SECRET_KEY=

# =============================================================================
# Alternative model presets
# =============================================================================

# --- Magnum v4 22B in pure FP16 (no quant) — A40 tight fit, 8K context max ---
# MODEL_REPO=anthracite-org/magnum-v4-22b
# MAX_MODEL_LEN=8192
# VLLM_EXTRA_ARGS=

# --- Magnum v4 12B (Mistral-Nemo base) — A40 comfortable, 32K context FP16 ---
# MODEL_REPO=anthracite-org/magnum-v4-12b
# MAX_MODEL_LEN=32768
# VLLM_EXTRA_ARGS=

# --- Cydonia 22B v1.3 — newer Mistral-Small creative/RP fine-tune ---
# MODEL_REPO=TheDrummer/Cydonia-22B-v1.3
# MAX_MODEL_LEN=32768
# VLLM_EXTRA_ARGS=--quantization fp8

# --- NemoMix Unleashed 12B — community merge, very lightly aligned ---
# MODEL_REPO=MarinaraSpaghetti/NemoMix-Unleashed-12B
# MAX_MODEL_LEN=32768
# VLLM_EXTRA_ARGS=

# --- General-purpose / non-creative ---

# Qwen2.5 14B Instruct — well-rounded assistant, A40-friendly, 128K capable
# MODEL_REPO=Qwen/Qwen2.5-14B-Instruct
# MAX_MODEL_LEN=65536
# VLLM_EXTRA_ARGS=

# Qwen2.5 1.5B Instruct — tiny, for local smoke tests on consumer GPUs
# MODEL_REPO=Qwen/Qwen2.5-1.5B-Instruct
# MAX_MODEL_LEN=8192
# GPU_MEMORY_UTILIZATION=0.85
# VLLM_EXTRA_ARGS=

# Llama 3.3 70B — requires 2x A100 80GB or 4x A40
# MODEL_REPO=meta-llama/Llama-3.3-70B-Instruct
# MAX_MODEL_LEN=131072
# GPU_MEMORY_UTILIZATION=0.95
# VLLM_EXTRA_ARGS=--tensor-parallel-size 2

# =============================================================================
# Gated HuggingFace models (Llama, Mistral, etc.) need an access token.
# Get one at https://huggingface.co/settings/tokens then uncomment:
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
