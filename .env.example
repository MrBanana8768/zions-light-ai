# =============================================================================
# Zion's Light AI - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust settings as needed:
#   cp .env.example .env
#
# For local testing, use the LOCAL TESTING section below.
# For production/Runpod, use the PRODUCTION section.
# =============================================================================

# =============================================================================
# LOCAL TESTING (Small model - ~2GB, works on most GPUs)
# =============================================================================
# Uncomment these for local testing with a lightweight model:

# MODEL_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
# MODEL_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf
# LLAMA_CTX_SIZE=8192
# LLAMA_N_GPU_LAYERS=999
# LLAMA_PARALLEL=2

# =============================================================================
# PRODUCTION (Qwen3-24B - ~18GB, requires A40/A100 or similar)
# =============================================================================
# Default configuration for Runpod deployment:

MODEL_REPO=DavidAU/Qwen3-24B-A4B-Freedom-Thinking-Abliterated-Heretic-NEO-Imatrix-GGUF
MODEL_FILE=Qwen3-24B-A4B-Freedom-Think-Ablit-Heretic-Neo-D_AU-Q6_K-imat.gguf
LLAMA_CTX_SIZE=32768
LLAMA_N_GPU_LAYERS=999
LLAMA_PARALLEL=4

# =============================================================================
# OpenWebUI Settings
# =============================================================================
WEBUI_AUTH=false
WEBUI_SECRET_KEY=

# =============================================================================
# Alternative Models for Testing
# =============================================================================
# TinyLlama (1.1B) - Very small, fast, ~700MB
# MODEL_REPO=TheBloke/TinyLlama-1.1B-Chat-v1.0-GGUF
# MODEL_FILE=tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
# LLAMA_CTX_SIZE=2048

# Qwen2.5-3B - Small but capable, ~2GB
# MODEL_REPO=Qwen/Qwen2.5-3B-Instruct-GGUF
# MODEL_FILE=qwen2.5-3b-instruct-q4_k_m.gguf
# LLAMA_CTX_SIZE=8192

# Qwen2.5-7B - Medium size, ~5GB
# MODEL_REPO=Qwen/Qwen2.5-7B-Instruct-GGUF
# MODEL_FILE=qwen2.5-7b-instruct-q4_k_m.gguf
# LLAMA_CTX_SIZE=16384
