# =============================================================================
# Zion's Light AI - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust settings as needed:
#   cp .env.example .env
#
# Stack: vLLM (inference) -> context-compactor (auto-summarization proxy) -> OpenWebUI
# =============================================================================

# =============================================================================
# MODEL — any HuggingFace causal-LM repo that vLLM supports
# =============================================================================
# Default: Magnum v4 22B — creative writing fine-tune of Mistral-Small-Instruct,
# lightly aligned, mimics Claude's prose style. On A40 (48GB), FP16 is a tight
# fit so we default to FP8 weight quantization for 32K context headroom.
MODEL_REPO=anthracite-org/magnum-v4-22b
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.90
# Runtime FP8 weight quantization — halves VRAM usage, ~99% quality retention.
# Remove if your GPU has ample VRAM and you want pure FP16 quality.
VLLM_EXTRA_ARGS=--quantization fp8

# =============================================================================
# CONTEXT COMPACTOR — Claude-style auto-summarization
# =============================================================================
# When total tokens in a request exceed COMPACTOR_TARGET_TOKENS, the older
# turns get summarized into a single system message and replaced.
# Leave COMPACTOR_TARGET_TOKENS empty to auto-default to 75% of MAX_MODEL_LEN.
COMPACTOR_TARGET_TOKENS=
COMPACTOR_KEEP_RECENT_TURNS=4
COMPACTOR_SUMMARY_MAX_TOKENS=1024

# =============================================================================
# V2.0 MEMORY — persistent facts (Phase 2)
# =============================================================================
# Extract memorable facts from each exchange and inject them into future
# requests as a system block. Async after response — no user-visible latency.

# Master switch. Set false to disable extraction (existing facts still
# load and inject; new ones just don't get added).
COMPACTOR_FACTS_EXTRACTION=true

# Soft cap on facts injection budget. ~1500 tokens ≈ 100-150 short bullets.
# When exceeded, LRU eviction (least-recently-used dropped).
COMPACTOR_MAX_FACTS_TOKENS=1500

# Max tokens for each extraction call's output. A few short bullets is
# usually plenty; tight cap keeps extraction fast.
COMPACTOR_FACTS_EXTRACTION_MAX_TOKENS=256

# =============================================================================
# V2.0 MEMORY — episodic / RAG (Phase 3)
# =============================================================================
# Every exchange is embedded (bge-small, CPU/ONNX) and stored in ChromaDB.
# On each request the latest user message retrieves the top-K most similar
# past exchanges, injected for exact recall. Set false to disable retrieval
# (facts memory still works).
COMPACTOR_RAG_ENABLED=true

# How many past exchanges to retrieve and inject per request.
COMPACTOR_RAG_TOP_K=5

# Embedding model (must be a fastembed-supported model). bge-small is
# English-tuned and baked into the image; changing this triggers a runtime
# download on first use.
COMPACTOR_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# =============================================================================
# V2.0 MEMORY — hierarchical summarization (Phase 4)
# =============================================================================
# Replaces v1's flat summary with tiered L1 (20-turn "scene" chunks) →
# L2 (10×L1 "chapter" summaries) → L3 (whole-conversation theme). The
# stack is injected as one more system block on each request; rollups
# happen async after the response, never blocking the user.
COMPACTOR_HIERARCHICAL_SUMMARY=true

# Threshold: turns per L1 chunk. Smaller = more granular but more LLM
# calls; larger = coarser but cheaper.
COMPACTOR_L1_CHUNK_SIZE=20

# Threshold: L1 chunks per L2 chapter rollup.
COMPACTOR_L2_CHUNK_SIZE=10

# Threshold: L2 chapters required before producing/refreshing L3.
COMPACTOR_L3_CHUNK_SIZE=5

# Per-tier LLM output budget. L3 is the largest because it summarizes the
# entire conversation; L1 the smallest because each chunk is one "scene".
COMPACTOR_L1_MAX_TOKENS=500
COMPACTOR_L2_MAX_TOKENS=1200
COMPACTOR_L3_MAX_TOKENS=2000

# =============================================================================
# V2.0 ADMIN ENDPOINTS — /admin/conversations/*
# =============================================================================
# Localhost-only by default. Set to 0.0.0.0 ONLY if you have auth or
# network-level isolation in front of the compactor port.
COMPACTOR_ADMIN_BIND=127.0.0.1

# Override the storage root if you want memory state somewhere other
# than /data/openwebui/compactor/ (e.g. local dev with a different mount).
# COMPACTOR_STORAGE_ROOT=/data/openwebui/compactor

# V2.1 Phase 6: post-boot live-stack self-test (writable storage, vLLM
# reachable, /health 200, real chat round-trip, facts write/read,
# admin localhost gating). Logs PASS/FAIL to /var/log/supervisor/
# selftest.log. Non-blocking: a FAIL never takes the pod down — it's
# observability, not a gate. Default true; set to "false" to skip.
# COMPACTOR_SELFTEST_ON_BOOT=true

# V2.1 Phase 8: persona-aware compaction.
# Auto-detect: when the first system message in a request is ≥ this many
# characters long, treat it as the conversation's persona — store it
# separately so it's exempt from summarizer churn + LRU fact eviction.
# COMPACTOR_PERSONA_AUTO_DETECT_MIN_CHARS=200
# Set to "false" to disable persona detection entirely (V2.0 behavior).
# COMPACTOR_PERSONA_ENABLED=true

# V2.3 Theme 1: data-durability backups.
# A periodic daemon snapshots webui.db + the compactor memory store to
# timestamped, verified tar.gz archives. Local-only for now (same volume) —
# protects against corruption / accidental delete / torn writes, NOT total
# volume loss (off-volume DR is planned future work).
# COMPACTOR_BACKUP_ENABLED=true            # set "false" to disable the daemon
# COMPACTOR_BACKUP_DIR=/data/backups       # where archives land
# COMPACTOR_BACKUP_INTERVAL_HOURS=24       # cadence
# COMPACTOR_BACKUP_RETAIN=7                # how many archives to keep
# COMPACTOR_BACKUP_MIN_FREE_MB=500         # skip a backup if /data is this low
# COMPACTOR_BACKUP_REMOTE=                 # (future) off-volume target; no-op today

# V2.3 Theme 2: pause new-memory WRITES (extraction/indexing/rollup/persona
# auto-capture) when free space on /data drops below this — keeps chat
# serving instead of crashing on a failed write. Explicit user writes
# (/remember, admin) are never gated.
# COMPACTOR_MIN_FREE_MB_WRITES=200

# V2.3 Theme 3: bound the post-response background work pool. At most
# MAX_CONCURRENT tails run at once; beyond MAX_OUTSTANDING total, new tails
# are shed (chat unaffected) rather than spawned unboundedly under load.
# COMPACTOR_MAX_CONCURRENT_TAILS=4
# COMPACTOR_MAX_OUTSTANDING_TAILS=64

# V2.3 Theme 4: operational confidence.
# Log format: "text" (default, human-readable) or "json" (one object per
# line, for grepping / shipping to a log aggregator).
# COMPACTOR_LOG_FORMAT=text
# Optional failure-alert webhook. When set, the boot self-test and backup
# daemon POST a JSON payload here on FAILURE (carries text/content fields so
# it works with Slack/Discord/generic receivers). Unset = no alerting.
# COMPACTOR_ALERT_WEBHOOK=
# COMPACTOR_ALERT_TIMEOUT_S=10

# =============================================================================
# OpenWebUI
# =============================================================================
WEBUI_AUTH=false
WEBUI_SECRET_KEY=

# =============================================================================
# Alternative model presets
# =============================================================================

# --- Magnum v4 22B in pure FP16 (no quant) — A40 tight fit, 8K context max ---
# MODEL_REPO=anthracite-org/magnum-v4-22b
# MAX_MODEL_LEN=8192
# VLLM_EXTRA_ARGS=

# --- Magnum v4 12B (Mistral-Nemo base) — A40 comfortable, 32K context FP16 ---
# MODEL_REPO=anthracite-org/magnum-v4-12b
# MAX_MODEL_LEN=32768
# VLLM_EXTRA_ARGS=

# --- Cydonia 22B v1.3 — newer Mistral-Small creative/RP fine-tune ---
# MODEL_REPO=TheDrummer/Cydonia-22B-v1.3
# MAX_MODEL_LEN=32768
# VLLM_EXTRA_ARGS=--quantization fp8

# --- NemoMix Unleashed 12B — community merge, very lightly aligned ---
# MODEL_REPO=MarinaraSpaghetti/NemoMix-Unleashed-12B
# MAX_MODEL_LEN=32768
# VLLM_EXTRA_ARGS=

# --- General-purpose / non-creative ---

# Qwen2.5 14B Instruct — well-rounded assistant, A40-friendly, 128K capable
# MODEL_REPO=Qwen/Qwen2.5-14B-Instruct
# MAX_MODEL_LEN=65536
# VLLM_EXTRA_ARGS=

# Qwen2.5 1.5B Instruct — tiny, for local smoke tests on consumer GPUs
# MODEL_REPO=Qwen/Qwen2.5-1.5B-Instruct
# MAX_MODEL_LEN=8192
# GPU_MEMORY_UTILIZATION=0.85
# VLLM_EXTRA_ARGS=

# Llama 3.3 70B — requires 2x A100 80GB or 4x A40
# MODEL_REPO=meta-llama/Llama-3.3-70B-Instruct
# MAX_MODEL_LEN=131072
# GPU_MEMORY_UTILIZATION=0.95
# VLLM_EXTRA_ARGS=--tensor-parallel-size 2

# --- V3.1 Vision (image understanding) — swap to a VLM ---
# Uploading images in OpenWebUI "just works" once the model can see; the
# compactor preserves image-bearing turns through compaction and budgets for
# image tokens (COMPACTOR_IMAGE_TOKENS below). vLLM serves these on the same
# OpenAI-compatible API. Trade-off: the best VLMs are not the best creative-
# writing models, so vision is an opt-in swap, not the default.
#
# Qwen2-VL 7B — solid generalist VLM, ~16 GB, comfortable on A40
# MODEL_REPO=Qwen/Qwen2-VL-7B-Instruct
# MAX_MODEL_LEN=32768
# VLLM_EXTRA_ARGS=--limit-mm-per-prompt image=4
#
# Pixtral 12B — Mistral's VLM, ~24 GB, A40 tight / A100 comfortable
# MODEL_REPO=mistralai/Pixtral-12B-2409
# MAX_MODEL_LEN=32768
# VLLM_EXTRA_ARGS=--limit-mm-per-prompt image=4 --tokenizer-mode mistral
#
# Llama-3.2 11B Vision — gated (needs HF_TOKEN), strong reasoning, ~24 GB
# MODEL_REPO=meta-llama/Llama-3.2-11B-Vision-Instruct
# MAX_MODEL_LEN=32768
# VLLM_EXTRA_ARGS=--limit-mm-per-prompt image=1 --enforce-eager
#
# Per-image token estimate the compactor adds to the budget so VLM requests
# don't overflow the real context window. Tune per model/resolution if the
# model errors on long image-heavy threads (raise it) or you have headroom
# to spare (lower it). Only matters when a VLM is in use.
# COMPACTOR_IMAGE_TOKENS=768

# =============================================================================
# Gated HuggingFace models (Llama, Mistral, etc.) need an access token.
# Get one at https://huggingface.co/settings/tokens then uncomment:
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
